{
    "compilerOptions": {
        "target": "es2015",
        "module": "commonjs",
        "baseUrl": "./",
        "paths": {
            "*": [
                "types/*"
            ]
        },
        "rootDir": "src",
        "outDir": "dist",
        "lib": [
            "es2019",
            "dom"
        ],
        "sourceMap": true,
        "declaration": true,
        "resolveJsonModule": true,
        "declarationDir": "./declarations",
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "allowSyntheticDefaultImports": true
    },
    "types": [
        "declarations/index.d.ts"
    ],
    "include": [
        "src/**/*.ts",
        "src/interfaces/IOutputs",
    ]
}